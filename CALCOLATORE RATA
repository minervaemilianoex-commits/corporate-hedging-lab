      ],
      "source": [
        "def chiedi_float(messaggio):\n",
        "    while True:\n",
        "        try:\n",
        "            valore = float(input(messaggio).replace(\",\", \".\").strip())\n",
        "            return valore\n",
        "        except ValueError:\n",
        "            print(\"Valore non valido. Inserisci un numero.\")\n",
        "\n",
        "\n",
        "def chiedi_int(messaggio):\n",
        "    while True:\n",
        "        try:\n",
        "            valore = int(input(messaggio).strip())\n",
        "            return valore\n",
        "        except ValueError:\n",
        "            print(\"Valore non valido. Inserisci un numero intero.\")\n",
        "\n",
        "\n",
        "def chiedi_scelta(messaggio, opzioni_valide):\n",
        "    while True:\n",
        "        valore = input(messaggio).strip().lower()\n",
        "        if valore in opzioni_valide:\n",
        "            return valore\n",
        "        print(f\"Scelta non valida. Opzioni possibili: {', '.join(opzioni_valide)}\")\n",
        "\n",
        "\n",
        "def chiedi_si_no(messaggio):\n",
        "    while True:\n",
        "        valore = input(messaggio + \" (s/n): \").strip().lower()\n",
        "        if valore in [\"s\", \"si\", \"sì\"]:\n",
        "            return True\n",
        "        if valore in [\"n\", \"no\"]:\n",
        "            return False\n",
        "        print(\"Rispondi con 's' oppure 'n'.\")\n",
        "\n",
        "\n",
        "def calcola_numero_canoni(durata_mesi, interpretazione_durata):\n",
        "    \"\"\"\n",
        "    interpretazione_durata:\n",
        "    - 'canoni': durata_mesi = numero di canoni effettivi\n",
        "    - 'compreso_anticipo': durata_mesi include l'anticipo iniziale, quindi canoni = durata_mesi - 1\n",
        "    \"\"\"\n",
        "    if interpretazione_durata == \"canoni\":\n",
        "        n_canoni = durata_mesi\n",
        "    elif interpretazione_durata == \"compreso_anticipo\":\n",
        "        n_canoni = durata_mesi - 1\n",
        "    else:\n",
        "        raise ValueError(\"Interpretazione durata non valida.\")\n",
        "\n",
        "    if n_canoni <= 0:\n",
        "        raise ValueError(\"Il numero di canoni deve essere maggiore di zero.\")\n",
        "\n",
        "    return n_canoni\n",
        "\n",
        "\n",
        "def calcola_rata_leasing(\n",
        "    importo_bene,\n",
        "    anticipo_importo,\n",
        "    riscatto_importo,\n",
        "    tan_percentuale,\n",
        "    n_canoni,\n",
        "    canoni_anticipati=False\n",
        "):\n",
        "    \"\"\"\n",
        "    Calcolo rata finanziaria pura.\n",
        "    \"\"\"\n",
        "\n",
        "    importo_finanziato = importo_bene - anticipo_importo\n",
        "    tan_decimale = tan_percentuale / 100\n",
        "    tasso_mensile = tan_decimale / 12\n",
        "\n",
        "    if importo_finanziato < 0:\n",
        "        raise ValueError(\"L'anticipo non può essere superiore all'importo del bene.\")\n",
        "\n",
        "    if riscatto_importo < 0:\n",
        "        raise ValueError(\"Il riscatto non può essere negativo.\")\n",
        "\n",
        "    if riscatto_importo > importo_bene:\n",
        "        print(\"\\nATTENZIONE: il riscatto è superiore all'importo del bene. \"\n",
        "              \"Non è impossibile come input, ma è molto sospetto.\\n\")\n",
        "\n",
        "    if tasso_mensile == 0:\n",
        "        rata = (importo_finanziato - riscatto_importo) / n_canoni\n",
        "    else:\n",
        "        fattore = (1 + tasso_mensile) ** n_canoni\n",
        "\n",
        "        if canoni_anticipati:\n",
        "            denominatore = ((1 - (1 + tasso_mensile) ** (-n_canoni)) / tasso_mensile) * (1 + tasso_mensile)\n",
        "            valore_attuale_riscatto = riscatto_importo / fattore\n",
        "            rata = (importo_finanziato - valore_attuale_riscatto) / denominatore\n",
        "        else:\n",
        "            valore_attuale_riscatto = riscatto_importo / fattore\n",
        "            rata = (importo_finanziato - valore_attuale_riscatto) * (tasso_mensile * fattore) / (fattore - 1)\n",
        "\n",
        "    return {\n",
        "        \"importo_finanziato\": importo_finanziato,\n",
        "        \"tasso_mensile\": tasso_mensile,\n",
        "        \"rata_finanziaria\": rata\n",
        "    }\n",
        "\n",
        "\n",
        "def main():\n",
        "    print(\"=== CALCOLATRICE LEASING COMPLETA ===\\n\")\n",
        "\n",
        "    # 1. Importo bene\n",
        "    importo_bene = chiedi_float(\"Inserisci l'importo del bene (€): \")\n",
        "\n",
        "    # 2. Anticipo\n",
        "    print(\"\\nANTICIPO\")\n",
        "    tipo_anticipo = chiedi_scelta(\n",
        "        \"Vuoi inserire l'anticipo come percentuale o importo? (percentuale/importo): \",\n",
        "        [\"percentuale\", \"importo\"]\n",
        "    )\n",
        "\n",
        "    if tipo_anticipo == \"percentuale\":\n",
        "        percentuale_anticipo = chiedi_float(\"Inserisci la percentuale di anticipo (%): \")\n",
        "        anticipo_importo = importo_bene * (percentuale_anticipo / 100)\n",
        "    else:\n",
        "        anticipo_importo = chiedi_float(\"Inserisci l'importo dell'anticipo (€): \")\n",
        "        percentuale_anticipo = (anticipo_importo / importo_bene) * 100 if importo_bene != 0 else 0\n",
        "\n",
        "    # 3. Riscatto / maxi rata\n",
        "    print(\"\\nRISCATTO / MAXI RATA\")\n",
        "    tipo_riscatto = chiedi_scelta(\n",
        "        \"Vuoi inserire il riscatto come percentuale o importo? (percentuale/importo): \",\n",
        "        [\"percentuale\", \"importo\"]\n",
        "    )\n",
        "\n",
        "    if tipo_riscatto == \"percentuale\":\n",
        "        percentuale_riscatto = chiedi_float(\"Inserisci la percentuale di riscatto (%): \")\n",
        "        riscatto_importo = importo_bene * (percentuale_riscatto / 100)\n",
        "    else:\n",
        "        riscatto_importo = chiedi_float(\"Inserisci l'importo del riscatto (€): \")\n",
        "        percentuale_riscatto = (riscatto_importo / importo_bene) * 100 if importo_bene != 0 else 0\n",
        "\n",
        "    # 4. TAN\n",
        "    print(\"\\nTASSO\")\n",
        "    tan = chiedi_float(\"Inserisci il TAN annuo nominale (%): \")\n",
        "\n",
        "    # 5. Durata\n",
        "    print(\"\\nDURATA\")\n",
        "    durata_mesi = chiedi_int(\"Inserisci la durata indicata nel preventivo/contratto (mesi): \")\n",
        "\n",
        "    print(\"\\nCome vuoi interpretare questa durata?\")\n",
        "    print(\"1 = la durata è già il numero di canoni effettivi\")\n",
        "    print(\"2 = la durata include l'anticipo iniziale, quindi i canoni sono mesi - 1\")\n",
        "\n",
        "    scelta_durata = chiedi_scelta(\"Scegli 1 o 2: \", [\"1\", \"2\"])\n",
        "\n",
        "    if scelta_durata == \"1\":\n",
        "        interpretazione_durata = \"canoni\"\n",
        "    else:\n",
        "        interpretazione_durata = \"compreso_anticipo\"\n",
        "\n",
        "    n_canoni = calcola_numero_canoni(durata_mesi, interpretazione_durata)\n",
        "\n",
        "    # 6. Canoni anticipati o posticipati\n",
        "    print(\"\\nTEMPISMO CANONI\")\n",
        "    canoni_anticipati = chiedi_si_no(\"I canoni sono anticipati?\")\n",
        "\n",
        "    # 7. Spese iniziali\n",
        "    print(\"\\nSPESE INIZIALI\")\n",
        "    spese_iniziali = chiedi_float(\"Inserisci eventuali spese iniziali (€, 0 se assenti): \")\n",
        "\n",
        "    # 8. Spese mensili\n",
        "    print(\"\\nSPESE MENSILI\")\n",
        "    spese_mensili = chiedi_float(\"Inserisci eventuali spese mensili per rata (€, 0 se assenti): \")\n",
        "\n",
        "    # 9. IVA\n",
        "    print(\"\\nIVA\")\n",
        "    applica_iva = chiedi_si_no(\"Vuoi simulare anche l'IVA sui canoni?\")\n",
        "    aliquota_iva = 0.0\n",
        "    if applica_iva:\n",
        "        aliquota_iva = chiedi_float(\"Inserisci l'aliquota IVA (%): \")\n",
        "\n",
        "    # Calcolo finanziario\n",
        "    risultati = calcola_rata_leasing(\n",
        "        importo_bene=importo_bene,\n",
        "        anticipo_importo=anticipo_importo,\n",
        "        riscatto_importo=riscatto_importo,\n",
        "        tan_percentuale=tan,\n",
        "        n_canoni=n_canoni,\n",
        "        canoni_anticipati=canoni_anticipati\n",
        "    )\n",
        "\n",
        "    rata_finanziaria = risultati[\"rata_finanziaria\"]\n",
        "    tasso_mensile = risultati[\"tasso_mensile\"]\n",
        "    importo_finanziato = risultati[\"importo_finanziato\"]\n",
        "\n",
        "    # IVA mensile\n",
        "    iva_mensile = 0.0\n",
        "    if applica_iva:\n",
        "        iva_mensile = rata_finanziaria * (aliquota_iva / 100)\n",
        "\n",
        "    rata_totale_mensile = rata_finanziaria + spese_mensili + iva_mensile\n",
        "\n",
        "    # Totali\n",
        "    totale_canoni_finanziari = rata_finanziaria * n_canoni\n",
        "    totale_spese_mensili = spese_mensili * n_canoni\n",
        "    totale_iva_canoni = iva_mensile * n_canoni\n",
        "\n",
        "    totale_pagato_complessivo = (\n",
        "        anticipo_importo\n",
        "        + spese_iniziali\n",
        "        + totale_canoni_finanziari\n",
        "        + totale_spese_mensili\n",
        "        + totale_iva_canoni\n",
        "        + riscatto_importo\n",
        "    )\n",
        "\n",
        "    # Distinzioni corrette\n",
        "    interessi_totali = (\n",
        "        anticipo_importo\n",
        "        + totale_canoni_finanziari\n",
        "        + riscatto_importo\n",
        "        - importo_bene\n",
        "    )\n",
        "\n",
        "    spese_totali = spese_iniziali + totale_spese_mensili\n",
        "\n",
        "    extra_totale_rispetto_al_bene = totale_pagato_complessivo - importo_bene\n",
        "\n",
        "    # Stampa risultati\n",
        "    print(\"\\n\" + \"=\" * 58)\n",
        "    print(\"RISULTATI DELLA SIMULAZIONE\")\n",
        "    print(\"=\" * 58)\n",
        "\n",
        "    print(f\"Importo del bene:              € {importo_bene:,.2f}\")\n",
        "    print(f\"Anticipo:                      € {anticipo_importo:,.2f} ({percentuale_anticipo:.2f}%)\")\n",
        "    print(f\"Importo finanziato:            € {importo_finanziato:,.2f}\")\n",
        "    print(f\"Riscatto / maxi rata:          € {riscatto_importo:,.2f} ({percentuale_riscatto:.2f}%)\")\n",
        "    print(f\"Durata inserita:               {durata_mesi} mesi\")\n",
        "    print(f\"Numero canoni usato:           {n_canoni}\")\n",
        "    print(f\"TAN:                           {tan:.2f}%\")\n",
        "    print(f\"Tasso mensile:                 {tasso_mensile:.6f}\")\n",
        "    print(f\"Tipo canoni:                   {'anticipati' if canoni_anticipati else 'posticipati'}\")\n",
        "    print(f\"Spese iniziali:                € {spese_iniziali:,.2f}\")\n",
        "    print(f\"Spese mensili:                 € {spese_mensili:,.2f}\")\n",
        "\n",
        "    if applica_iva:\n",
        "        print(f\"IVA applicata sui canoni:      {aliquota_iva:.2f}%\")\n",
        "        print(f\"IVA mensile stimata:           € {iva_mensile:,.2f}\")\n",
        "    else:\n",
        "        print(\"IVA applicata sui canoni:      no\")\n",
        "        print(f\"IVA mensile stimata:           € {iva_mensile:,.2f}\")\n",
        "\n",
        "    print(\"-\" * 58)\n",
        "    print(f\"Rata finanziaria netta:        € {rata_finanziaria:,.2f}\")\n",
        "    print(f\"Rata totale simulata:          € {rata_totale_mensile:,.2f}\")\n",
        "    print(\"-\" * 58)\n",
        "    print(f\"Totale canoni finanziari:      € {totale_canoni_finanziari:,.2f}\")\n",
        "    print(f\"Totale IVA canoni:             € {totale_iva_canoni:,.2f}\")\n",
        "    print(f\"Totale spese iniziali+mensili: € {spese_totali:,.2f}\")\n",
        "    print(\"-\" * 58)\n",
        "    print(f\"Interessi totali stimati:      € {interessi_totali:,.2f}\")\n",
        "    print(f\"IVA totale stimata:            € {totale_iva_canoni:,.2f}\")\n",
        "    print(f\"Extra totale rispetto al bene: € {extra_totale_rispetto_al_bene:,.2f}\")\n",
        "    print(f\"Totale pagato complessivo:     € {totale_pagato_complessivo:,.2f}\")\n",
        "    print(\"=\" * 58)\n",
        "\n",
        "    print(\"\\nLETTURA CORRETTA DEL REPORT:\")\n",
        "    print(\"- Gli interessi totali stimati rappresentano il costo finanziario puro del leasing.\")\n",
        "    print(\"- L'IVA totale stimata è separata, quindi non viene confusa con gli interessi.\")\n",
        "    print(\"- L'extra totale rispetto al bene include interessi, IVA e spese.\")\n",
        "    print(\"- Per valutare il costo del finanziamento, guarda soprattutto la voce 'Interessi totali stimati'.\")\n",
        "\n",
        "    print(\"\\nNOTA:\")\n",
        "    print(\"Questa è una simulazione finanziaria avanzata. Un preventivo reale può comunque\")\n",
        "    print(\"differire per commissioni bancarie, imposte, assicurazioni, arrotondamenti,\")\n",
        "    print(\"prima rata irregolare o modalità di calcolo interne della società.\")\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    main()"
      ]
    }
